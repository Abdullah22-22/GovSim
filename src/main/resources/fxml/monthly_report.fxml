<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.govsim.govsim.gui.MonthlyReportController"
    stylesheets="@../css/app.css"
    styleClass="popup-bg"
    spacing="15" prefWidth="700" prefHeight="600">

    <!-- Header -->
    <HBox styleClass="popup-header">
        <Label fx:id="monthYearLabel" text="MONTHLY REPORT" styleClass="popup-title"/>
    </HBox>

    <!-- Ministry cards -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="popup-scroll">
        <VBox fx:id="ministriesContainer" spacing="10" style="-fx-padding: 5;"/>
    </ScrollPane>

    <!-- Confirm -->
    <Button text="CONFIRM ALL DECISIONS"
            onAction="#handleConfirm"
            prefWidth="9999" prefHeight="45"
            styleClass="btn-confirm-green"/>

</VBox>
