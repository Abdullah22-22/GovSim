<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.govsim.govsim.gui.AnnualReviewController"
    stylesheets="@../css/app-popups.css"
    styleClass="popup-bg"
    spacing="15" prefWidth="700" prefHeight="650">

    <!-- Header -->
    <HBox styleClass="popup-header-annual">
        <Label fx:id="yearLabel" text="ANNUAL MINISTER REVIEW" styleClass="popup-title-annual"/>
    </HBox>

    <!-- Ministers list -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="popup-scroll">
        <VBox fx:id="ministersContainer" spacing="10" style="-fx-padding: 5;"/>
    </ScrollPane>

    <!-- Confirm -->
    <Button text="CONFIRM ALL DECISIONS"
            onAction="#handleConfirm"
            prefWidth="9999" prefHeight="45"
            styleClass="btn-confirm-yellow"/>

</VBox>
