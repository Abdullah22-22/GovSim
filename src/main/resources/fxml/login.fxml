<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #0f1419;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.govsim.govsim.gui.LoginController">
   <center>
      <HBox alignment="CENTER" spacing="40">
         <!-- Left side - Branding -->
         <VBox alignment="CENTER" spacing="20" prefWidth="350">
            <Label text="⚙" style="-fx-font-size: 80; -fx-text-fill: #f1c40f;"/>
            <Label text="GOVSIM" style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
            <Label text="Government Simulation Engine" style="-fx-font-size: 16; -fx-text-fill: #7f8fa3;"/>
            <Label text="Make strategic decisions to lead your nation." style="-fx-font-size: 13; -fx-text-fill: #95a5a6; -fx-padding: 20 0 0 0;" wrapText="true"/>
         </VBox>
         
         <!-- Right side - Login Form -->
         <VBox alignment="CENTER" spacing="20" prefWidth="350">
            <Label text="LOGIN" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
            
            <!-- Username -->
            <VBox spacing="8">
               <Label text="USERNAME" style="-fx-font-size: 11; -fx-text-fill: #7f8fa3; -fx-text-transform: uppercase;"/>
               <TextField fx:id="usernameField" prefHeight="45" promptText="Enter your username" 
                         style="-fx-font-size: 13; -fx-padding: 12; -fx-background-color: #1a1f3a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #5a6a7a; -fx-border-color: #2a3f5f; -fx-border-width: 1; -fx-border-radius: 3;"/>
            </VBox>
            
            <!-- Password -->
            <VBox spacing="8">
               <Label text="PASSWORD" style="-fx-font-size: 11; -fx-text-fill: #7f8fa3; -fx-text-transform: uppercase;"/>
               <PasswordField fx:id="passwordField" prefHeight="45" promptText="Enter your password"
                             style="-fx-font-size: 13; -fx-padding: 12; -fx-background-color: #1a1f3a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #5a6a7a; -fx-border-color: #2a3f5f; -fx-border-width: 1; -fx-border-radius: 3;"/>
            </VBox>
            
            <!-- Error Message -->
            <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;" wrapText="true" minHeight="20"/>
            
            <!-- Login Button -->
            <Button prefHeight="45" prefWidth="350" text="LOGIN" onAction="#handleLogin"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 0;" />
            
            <!-- Divider -->
            <Label text="Don't have an account?" style="-fx-font-size: 11; -fx-text-fill: #7f8fa3; -fx-padding: 10 0 10 0;"/>
            
            <!-- Register Button -->
            <Button prefHeight="45" prefWidth="350" text="CREATE ACCOUNT" onAction="#handleRegister"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 0;" />
         </VBox>
      </HBox>
   </center>
</BorderPane>