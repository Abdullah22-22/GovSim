<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.govsim.govsim.gui.AISidebarController"
        styleClass="sidebar-container"
        spacing="0" VBox.vgrow="ALWAYS">

    <!-- Header -->
    <HBox styleClass="sidebar-header" spacing="8" alignment="CENTER_LEFT">
        <Label fx:id="headerLabel" text="AI ADVISOR" styleClass="sidebar-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="headerIcon" text="🤖" style="-fx-font-size: 16;"/>
    </HBox>

    <!-- Content -->
    <ScrollPane fitToWidth="true" styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
        <VBox fx:id="contentContainer" spacing="8" styleClass="sidebar-events-list">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
        </VBox>
    </ScrollPane>

</VBox>
